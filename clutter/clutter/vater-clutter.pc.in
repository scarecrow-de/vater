prefix=@prefix@
exec_prefix=@exec_prefix@
apiversion=@LIBVATER_API_VERSION@
libdir=@libdir@/vater-${apiversion}
includedir=@includedir@/vater-${apiversion}

requires=@CLUTTER_REQUIRES@ vater-cogl-${apiversion}
requires_private=@CLUTTER_REQUIRES_PRIVATE@
backends=@CLUTTER_BACKENDS@

# only kept for backward compatibility
soname_infix=@CLUTTER_SONAME_INFIX@
winsys=@CLUTTER_WINSYS@
backend=@CLUTTER_WINSYS@
cogl=deprecated
cogl_driver=deprecated

Name: Vater Clutter
Description: Vater's Clutter Private Library
Version: @VATER_VERSION@
Libs: -L${libdir} -lvater-clutter-${apiversion}
Cflags: -I${includedir}/clutter
Requires: ${requires}
Requires.private: ${requires_private}

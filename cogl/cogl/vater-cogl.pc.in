prefix=@prefix@
exec_prefix=@exec_prefix@
apiversion=@LIBVATER_API_VERSION@
libdir=@libdir@/vater-${apiversion}
includedir=@includedir@/vater-${apiversion}
requires=@COGL_PKG_REQUIRES@

Name: Cogl
Description: An object oriented GL/GLES Abstraction/Utility Layer
Version: @VATER_VERSION@
Libs: -L${libdir} -lvater-cogl-${apiversion}
Cflags: -I${includedir}/cogl
Requires: ${requires}

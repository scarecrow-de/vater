prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@
apiversion=@LIBVATER_API_VERSION@
girdir=@libdir@/vater-${apiversion}
typelibdir=@libdir@/vater-${apiversion}

Name: libvater
Description: Vater window manager library
Requires: gsettings-desktop-schemas gtk+-3.0 vater-clutter-${apiversion} x11
Version: @VERSION@
Libs: -L${libdir} -lvater-${apiversion}
Cflags: -I${includedir}/vater-${apiversion}
